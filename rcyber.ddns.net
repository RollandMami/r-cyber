server {
    listen 80;
    listen [::]:80;
    server_name rcyber.ddns.net;

    # ── Logs ──────────────────────────────────────────────────
    access_log /var/log/nginx/rcyber_access.log;
    error_log  /var/log/nginx/rcyber_error.log;

    # ── Fichiers statiques Django ──────────────────────────────
    location /static/ {
        alias /var/www/rcyber/app/staticfiles/;
        expires 30d;
        add_header Cache-Control "public, immutable";
    }

    # ── Fichiers media (uploads IFC, PDF, photos…) ────────────
    location /media/ {
        alias /var/www/rcyber/app/media/;
        expires 7d;
        add_header Cache-Control "public";
    }

    # ── Proxy vers Gunicorn (Django) ──────────────────────────
    location / {
        proxy_pass         http://127.0.0.1:8000;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;

        # Timeout étendu (conversion IFC peut être longue)
        proxy_read_timeout    300s;
        proxy_connect_timeout 60s;
        proxy_send_timeout    300s;

        # Taille max upload (fichiers IFC peuvent être volumineux)
        client_max_body_size 512M;
    }
}
